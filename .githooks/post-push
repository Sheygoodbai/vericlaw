#!/usr/bin/env bash
set -euo pipefail

if [[ "${VERICLAW_SKIP_CLAWHUB_AUTO_PUBLISH:-0}" == "1" ]]; then
  exit 0
fi

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$ROOT_DIR" ]]; then
  exit 0
fi

publish_needed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue
  [[ "$remote_ref" != "refs/heads/main" ]] && continue

  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    changed_files="$(git -C "$ROOT_DIR" diff-tree --no-commit-id --name-only -r "$local_sha")"
  else
    changed_files="$(git -C "$ROOT_DIR" diff --name-only "$remote_sha..$local_sha")"
  fi

  if printf '%s\n' "$changed_files" | rg -q \
    '^(clawhub/vericlaw-plugin/|README\.md$|docs/index\.html$|docs/download/index\.html$|LICENSE$|NOTICE$|ATTRIBUTION\.md$|TRADEMARKS\.md$|PATENTS\.md$|INFRINGEMENT\.md$|LEGAL_ENFORCEMENT\.md$)'; then
    publish_needed=1
    break
  fi
done

if [[ "$publish_needed" != "1" ]]; then
  exit 0
fi

"$ROOT_DIR/scripts/clawhub-package-publish-local.sh"
